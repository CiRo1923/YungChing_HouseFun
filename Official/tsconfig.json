{
  // https://nuxt.com/docs/guide/concepts/typescript
  "extends": "./.nuxt/tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./*"],
      "~/*": ["./*"],
      "@stores/*": ["./stores/*"],
      "@components/*": ["./components/*"],
      "@container/*": ["./container/*"],
      "@composable/*": ["./composable/*"],
      "@pages/*": ["./pages/*"],
      "@imgs/*": ["./assets/images/*"],
      "@css/*": ["./assets/css/*"],
      "@js/*": ["./assets/js/*"]
    },
    "types": ["node"]
  }
}
